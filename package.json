{
  "name": "@rrulenet/rrule",
  "version": "0.1.3",
  "description": "Classic rrule.js-style recurrence API, backed by a maintained engine built for production scheduling.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rrulenet/rrule.git"
  },
  "homepage": "https://github.com/rrulenet/rrule#readme",
  "bugs": {
    "url": "https://github.com/rrulenet/rrule/issues"
  },
  "keywords": [
    "rrule",
    "recurrence",
    "rfc5545",
    "ical",
    "temporal",
    "calendar"
  ],
  "files": [
    "assets",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test test/**/*.test.js",
    "coverage": "npm run build && node --experimental-test-coverage --test-coverage-include=dist/**/*.js --test test/**/*.test.js",
    "coverage:badge": "node scripts/write-coverage-badge.mjs coverage-output.txt badges/coverage.json",
    "typecheck": "tsc --noEmit",
    "perf": "npm run build && node perf/perf.mjs"
  },
  "dependencies": {
    "@rrulenet/core": "^0.1.3",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
